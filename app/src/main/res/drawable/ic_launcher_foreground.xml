<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    
    <!-- Outer Speedometer Dashboard Arc -->
    <path
        android:pathData="M 32 72 A 26 26 0 1 1 76 72"
        android:strokeWidth="5"
        android:strokeLineCap="round"
        android:fillColor="#00000000">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="26"
                android:startY="54"
                android:endX="82"
                android:endY="54"
                android:type="linear">
                <item android:color="#00ACC1" android:offset="0.0" />
                <item android:color="#00E5FF" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Glowing Heartbeat Pulse wave running through the speedometer center -->
    <path
        android:pathData="M 28 54 L 41 54 L 46 32 L 52 76 L 58 40 L 63 59 L 67 54 L 80 54"
        android:strokeWidth="4.5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="28"
                android:startY="54"
                android:endX="80"
                android:endY="54"
                android:type="linear">
                <item android:color="#00E5FF" android:offset="0.0" />
                <item android:color="#00FFB3" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Minimalist speed level tick indicators (drawn with standard path commands) -->
    <!-- Circle at (54, 28) with radius 2 -->
    <path
        android:pathData="M 54,26 a 2,2 0 1,0 0,4 a 2,2 0 1,0 0,-4"
        android:fillColor="#FFFFFF" />
    
    <!-- Circle at (32, 42) with radius 1.5 -->
    <path
        android:pathData="M 32,40.5 a 1.5,1.5 0 1,0 0,3 a 1.5,1.5 0 1,0 0,-3"
        android:fillColor="#80FFFFFF" />

    <!-- Circle at (76, 42) with radius 1.5 -->
    <path
        android:pathData="M 76,40.5 a 1.5,1.5 0 1,0 0,3 a 1.5,1.5 0 1,0 0,-3"
        android:fillColor="#80FFFFFF" />
</vector>
